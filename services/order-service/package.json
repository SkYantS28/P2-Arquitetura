{
  "name": "order-service",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run test:unit && npm run test:bdd",
    "test:unit": "vitest run",
    "test:bdd": "tsx ../../node_modules/@cucumber/cucumber/bin/cucumber-js tests/bdd/*.feature --import tests/bdd/**/*.js",
    "dev": "tsx watch src/server.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.2.0",
    "@types/pg": "^8.15.5",
    "@types/express": "^5.0.3",
    "@types/cors": "^2.8.19",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.4",
    "typescript": "^5.8.3",
    "tsx": "^4.20.3",
    "vitest": "^3.2.4"
  }
}
